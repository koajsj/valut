<?xml version="1.0" encoding="utf-8"?>
<!--
  Compatibility mode lets the autofill framework work inside browsers that render web pages as a
  virtual view hierarchy (no native autofill hints). Each listed browser package is opted in up to
  the given version code. Native apps do not need this.
-->
<autofill-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.offlinevault.MainActivity">
    <compatibility-package android:name="com.android.chrome" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.chrome.beta" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.chrome.dev" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="org.mozilla.firefox" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="org.mozilla.focus" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.microsoft.emmx" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.brave.browser" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.opera.browser" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.opera.mini.native" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.sec.android.app.sbrowser" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.duckduckgo.mobile.android" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.vivaldi.browser" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.kiwibrowser.browser" android:maxLongVersionCode="2147483647" />
    <compatibility-package android:name="com.UCMobile.intl" android:maxLongVersionCode="2147483647" />
</autofill-service>
