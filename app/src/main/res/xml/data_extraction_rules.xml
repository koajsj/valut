<?xml version="1.0" encoding="utf-8"?>
<!-- Disable cloud backup and device-to-device transfer of app data.
     The encrypted vault must never leave the device automatically. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
